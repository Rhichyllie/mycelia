generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GovernedRun {
  id            String   @id
  tenantId      String
  correlationId String
  currentState  String
  status        String
  resourceRef   String
  requesterRef  String
  purpose       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  runtimeStateSnapshots RuntimeStateSnapshot[]
  policyDecisionRecords PolicyDecisionRecord[]
  admissionDecisions    AdmissionDecisionRecord[]
  approvalRequests      ApprovalRequest[]
  auditRecords          AuditRecord[]

  @@unique([tenantId, correlationId])
  @@index([tenantId])
}

model RuntimeStateSnapshot {
  id            String   @id
  tenantId      String
  governedRunId String
  state         String
  sequence      Int
  reasonCode    String
  safeSummary   String
  createdAt     DateTime @default(now())

  governedRun GovernedRun @relation(fields: [governedRunId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([governedRunId])
}

model PolicyDecisionRecord {
  id            String   @id
  tenantId      String
  governedRunId String
  riskLevel     String
  outcome       String
  reasonCode    String
  safeSummary   String
  policyRef     String
  createdAt     DateTime @default(now())

  governedRun GovernedRun @relation(fields: [governedRunId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([governedRunId])
}

model AdmissionDecisionRecord {
  id                  String   @id
  tenantId            String
  governedRunId       String
  outcome             String
  reasonCode          String
  safeSummary         String
  lifecycleIntentHint String
  createdAt           DateTime @default(now())

  governedRun      GovernedRun       @relation(fields: [governedRunId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  approvalRequests ApprovalRequest[]

  @@index([tenantId])
  @@index([governedRunId])
}

model ApprovalRequest {
  id                        String   @id
  tenantId                  String
  governedRunId             String
  admissionDecisionRecordId String
  status                    String
  requestedRole             String
  requesterRef              String
  approverRef               String?
  decisionOutcome           String?
  decisionReasonCode        String?
  safeDecisionSummary       String?
  createdAt                 DateTime @default(now())
  decidedAt                 DateTime?

  governedRun             GovernedRun             @relation(fields: [governedRunId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  admissionDecisionRecord AdmissionDecisionRecord @relation(fields: [admissionDecisionRecordId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([governedRunId])
  @@index([admissionDecisionRecordId])
}

model AuditRecord {
  id             String   @id
  tenantId       String
  governedRunId  String
  moment         String
  requirement    String
  recordKindHint String
  reasonCode     String
  safeSummary    String
  subjectRef     String
  actorRef       String?
  evidenceRef    String?
  createdAt      DateTime @default(now())

  governedRun GovernedRun @relation(fields: [governedRunId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([governedRunId])
}

model AppUser {
  id              String   @id @default(uuid())
  tenantId        String
  email           String
  emailNormalized String
  displayName     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authIdentities        AuthIdentity[]
  workspaceMemberships WorkspaceMembership[]

  @@unique([tenantId, emailNormalized])
  @@index([tenantId])
  @@index([emailNormalized])
  @@map("app_users")
}

model AuthIdentity {
  id           String   @id @default(uuid())
  userId       String
  providerType String
  providerId   String
  subject      String
  emailAtLogin String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, subject])
  @@index([userId])
  @@map("auth_identities")
}
model Workspace {
  id            String   @id @default(uuid())
  tenantId      String
  slug          String
  name          String
  ownerIdentity String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships WorkspaceMembership[]
  projects    Project[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("workspaces")
}

model WorkspaceMembership {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String
  userId      String
  role        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workspaceId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([workspaceId, role])
  @@map("workspace_memberships")
}

model Project {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String
  slug        String
  name        String
  description String?
  template    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes        Node[]
  edges        Edge[]
  externalRefs ExternalRef[]

  @@unique([tenantId, workspaceId, slug])
  @@index([tenantId])
  @@index([workspaceId])
  @@map("projects")
}

model Node {
  id        String   @id @default(uuid())
  tenantId  String
  projectId String
  kind      String
  label     String
  positionX Float
  positionY Float
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outgoing     Edge[]        @relation("EdgeSource")
  incoming     Edge[]        @relation("EdgeTarget")
  externalRefs ExternalRef[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("nodes")
}

model Edge {
  id           String   @id @default(uuid())
  tenantId     String
  projectId    String
  sourceNodeId String
  targetNodeId String
  kind         String
  label        String?
  data         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNode   Node          @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   Node          @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  externalRefs ExternalRef[]

  @@index([tenantId])
  @@index([projectId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("edges")
}

model ExternalRef {
  id         String   @id @default(uuid())
  tenantId   String
  projectId  String
  nodeId     String?
  edgeId     String?
  system     String
  externalId String
  locator    String
  metadata   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  edge    Edge?   @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  node    Node?   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, system, externalId, nodeId, edgeId])
  @@index([tenantId])
  @@index([projectId])
  @@index([nodeId])
  @@index([edgeId])
  @@map("external_refs")
}

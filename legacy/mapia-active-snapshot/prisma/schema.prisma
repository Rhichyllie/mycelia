generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            String       @id @default(uuid()) @db.Uuid
  slug          String       @unique @db.VarChar(80)
  name          String       @db.VarChar(120)
  ownerIdentity String?      @db.VarChar(255)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  auditEvents   AuditEvent[]
  memberships   WorkspaceMembership[]
  projects      Project[]

  @@map("workspaces")
}

model AppUser {
  id              String                @id @default(uuid()) @db.Uuid
  email           String                @db.VarChar(255)
  emailNormalized String                @unique @db.VarChar(255)
  displayName     String?               @db.VarChar(120)
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  authIdentities  AuthIdentity[]
  memberships     WorkspaceMembership[]

  @@index([emailNormalized])
  @@map("app_users")
}

model AuthIdentity {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  providerType AuthProviderType
  providerId   String           @db.VarChar(80)
  subject      String           @db.VarChar(255)
  emailAtLogin String?          @db.VarChar(255)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  lastSeenAt   DateTime?
  user         AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, subject])
  @@index([userId])
  @@map("auth_identities")
}

model WorkspaceMembership {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  @@map("workspace_memberships")
}

model Project {
  id            String          @id @default(uuid()) @db.Uuid
  workspaceId   String          @db.Uuid
  slug          String          @db.VarChar(80)
  name          String          @db.VarChar(120)
  description   String?         @db.VarChar(500)
  template      ProjectTemplate
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  auditEvents   AuditEvent[]
  creationSettings ProjectCreationSettings?
  creationDraft    ProjectCreationDraft?
  editorSnapshotVersions EditorSnapshotVersion[]
  edges         Edge[]
  externalRefs  ExternalRef[]
  graphVersions GraphVersion[]
  nodes         Node[]
  semanticEventLogs SemanticEventLog[]
  semanticPolicy SemanticPolicy?
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  legacyCreationFlowDraft LegacyCreationFlowDraft?

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("projects")
}

model ProjectCreationSettings {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @unique @db.Uuid
  profile       String?  @db.VarChar(80)
  startStrategy String?  @db.VarChar(80)
  startSource   String?  @db.VarChar(80)
  templatePreset String? @db.VarChar(80)
  initialView   String?  @db.VarChar(80)
  layout        String?  @db.VarChar(80)
  detailLevel   String?  @db.VarChar(80)
  sourceConfig  Json?
  automation    Json?
  context       Json?
  appliedSettings Json?
  appliedVersion Int      @default(1)
  appliedAt      DateTime?
  appliedByIdentity String? @db.VarChar(255)
  draftPayload  Json?
  draftVersion  Int      @default(1)
  draftUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_creation_settings")
}

model ProjectCreationDraft {
  id              String   @id @default(uuid()) @db.Uuid
  projectId        String   @unique @db.Uuid
  draftPayloadJson Json
  draftVersion     Int      @default(1)
  updatedByIdentity String? @db.VarChar(255)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_creation_drafts")
}

model CreationTelemetryEvent {
  id                String   @id @default(uuid()) @db.Uuid
  eventName         String   @db.VarChar(120)
  eventVersion      Int
  eventId           String   @db.VarChar(120)
  dedupeKey         String?  @db.VarChar(180)
  emittedAt         DateTime
  ingestedAt        DateTime @default(now())
  environment       String   @db.VarChar(40)
  releaseVersion    String   @db.VarChar(80)
  serviceName       String   @db.VarChar(80)
  requestId         String   @db.VarChar(120)
  traceId           String   @db.VarChar(120)
  correlationId     String   @db.VarChar(120)
  causationId       String?  @db.VarChar(120)
  actorType         String   @db.VarChar(40)
  actorIdentityHash String?  @db.VarChar(128)
  projectId         String?  @db.Uuid
  classification    String   @db.VarChar(40)
  piiLevel          String   @db.VarChar(40)
  retentionClass    String   @db.VarChar(40)
  payload           Json

  @@index([eventName, emittedAt])
  @@index([emittedAt])
  @@index([projectId, emittedAt])
  @@unique([eventName, eventVersion, dedupeKey])
  @@map("creation_telemetry_events")
}

/// Legado transitorio: storage antigo do fluxo de criacao antes do Creation Assistant.
model LegacyCreationFlowDraft {
  id          String                   @id @default(uuid()) @db.Uuid
  projectId   String                   @unique @db.Uuid
  status      LegacyCreationFlowStatus @default(draft)
  currentStep LegacyCreationFlowStep   @default(template)
  payload     Json
  lastError   String?                  @db.VarChar(500)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("wizard_drafts")
}

model GraphVersion {
  /// Legacy physical model name mapped to graph_versions.
  /// Active code semantics above this boundary are WorkingSnapshot / working snapshot storage.
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  versionNumber     Int
  revision          Int      @default(1)
  label             String?  @db.VarChar(200)
  snapshot          Json
  viewport          Json
  createdByIdentity String?  @db.VarChar(255)
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId, createdAt])
  @@map("graph_versions")
}

model SemanticPolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  projectId             String   @unique @db.Uuid
  diagramType           String?  @db.VarChar(80)
  strictEnabled         Boolean  @default(true)
  enforceOnServer       Boolean  @default(true)
  allowTechOverride     Boolean  @default(false)
  requireOverrideReason Boolean  @default(true)
  customRulesJson       Json?
  version               Int      @default(1)
  updatedByIdentity     String?  @db.VarChar(255)
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
  @@map("semantic_policies")
}

model SemanticEventLog {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @db.Uuid
  actorIdentity String?  @db.VarChar(255)
  eventType     String   @db.VarChar(120)
  severity      String?  @db.VarChar(20)
  payloadJson   Json
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("semantic_event_logs")
}

model EditorSnapshotVersion {
  /// Legacy physical model name mapped to editor_snapshot_versions.
  /// Active code semantics above this boundary are immutable snapshot versions.
  id        String                @id @default(uuid()) @db.Uuid
  projectId String                @db.Uuid
  snapshot  Json
  label     String?               @db.VarChar(200)
  origin    SnapshotVersionOrigin @default(manual)
  createdAt DateTime              @default(now())
  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
  @@map("editor_snapshot_versions")
}

model Node {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @db.Uuid
  kind         NodeKind
  label        String        @db.VarChar(200)
  positionX    Float
  positionY    Float
  data         Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  outgoing     Edge[]        @relation("EdgeSource")
  incoming     Edge[]        @relation("EdgeTarget")
  externalRefs ExternalRef[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("nodes")
}

model Edge {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @db.Uuid
  sourceNodeId String        @db.Uuid
  targetNodeId String        @db.Uuid
  kind         EdgeKind
  label        String?       @db.VarChar(200)
  data         Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNode   Node          @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   Node          @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  externalRefs ExternalRef[]

  @@index([projectId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("edges")
}

model ExternalRef {
  id         String         @id @default(uuid()) @db.Uuid
  projectId  String         @db.Uuid
  nodeId     String?        @db.Uuid
  edgeId     String?        @db.Uuid
  system     ExternalSystem
  externalId String         @db.VarChar(255)
  locator    Json
  metadata   Json
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  edge       Edge?          @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  node       Node?          @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, system, externalId, nodeId, edgeId])
  @@index([projectId])
  @@index([nodeId])
  @@index([edgeId])
  @@map("external_refs")
}

model AuditEvent {
  id            String          @id @default(uuid()) @db.Uuid
  workspaceId   String?         @db.Uuid
  projectId     String?         @db.Uuid
  entityType    AuditEntityType
  entityId      String          @db.VarChar(255)
  action        AuditAction
  actorUserId   String?         @db.Uuid
  actorIdentity String?         @db.VarChar(255)
  payload       Json
  createdAt     DateTime        @default(now())
  project       Project?        @relation(fields: [projectId], references: [id])
  workspace     Workspace?      @relation(fields: [workspaceId], references: [id])

  @@index([actorUserId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([entityType, entityId])
  @@map("audit_events")
}

enum ProjectTemplate {
  sitemap
  flowchart
  erd
  graph
}

enum NodeKind {
  workspace
  project
  entity
  page
  flow_step
  note
}

enum EdgeKind {
  contains
  references
  depends_on
  flows_to
  relates_to
}

enum ExternalSystem {
  manual
  postgres
  prisma
}

enum AuthProviderType {
  development_credentials
  oidc
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

enum AuditEntityType {
  workspace
  project
  graph_version
  node
  edge
}

enum AuditAction {
  created
  updated
  deleted
  restored
  imported
  exported
  denied
}

enum LegacyCreationFlowStatus {
  draft
  validating
  generating
  ready
  error

  @@map("WizardDraftStatus")
}

enum LegacyCreationFlowStep {
  template
  diagram_type
  data_source
  config
  review

  @@map("WizardStep")
}

enum SnapshotVersionOrigin {
  manual
}
